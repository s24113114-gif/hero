<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        body { font-family: sans-serif; padding: 20px; line-height: 1.6; }
        .student-info { color: #666; margin-bottom: 20px; border-bottom: 1px solid #ccc; }
        li { margin-bottom: 10px; }
        strong { color: #d9534f; }
    </style>
</head>
<body>
    <h1><%= title %></h1>
    
    <div class="student-info">
        <p>24113114：<strong><%= studentId %></strong></p>
    </div>

    <ul>
        <% heroes.forEach(hero => { %>
            <li>
                <strong><%= hero.name %></strong> - <%= hero.detail %>
            </li>
        <% }) %>
    </ul>
</body>
</html>